PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/subscription-api
MONGO_ROOT_PASSWORD=admin123
MONGO_DB=subscription-api
BCRYPT_SALT_ROUNDS=12
JWT_ACCESS_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=7d
JWT_PASSWORD_SECRET=change_me
JWT_PASSWORD_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change_me
JWT_REFRESH_EXPIRES_IN=10d
RESET_PASS_UI_LINK=http://localhost:3000/reset_password/
FRONTEND_URLS=http://localhost:3000,http://localhost:3001
REDIS_URL=redis://localhost:6379
REDIS_CACHE_KEY_PREFIX=subscription-api
REDIS_TTL=3600
REDIS_TTL_ACCESS_TOKEN=3600
REDIS_TTL_REFRESH_TOKEN=864000
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:4000/api/v1/subscriptions/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:4000/api/v1/subscriptions/cancel?session_id={CHECKOUT_SESSION_ID}

# Existing optional payment gateway settings kept for backwards compatibility
STORE_ID=
STORE_PASSWD=
IS_LIVE=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
